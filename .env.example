# Spring profile
SPRING_PROFILES_ACTIVE=dev

# FastAPI base URL
PYTHON_BASE_URL=http://localhost:8000

# MySQL local development settings
MYSQL_DATABASE=chok
MYSQL_USER=chok-spring
MYSQL_PASSWORD=chok-spring
MYSQL_ROOT_PASSWORD=root

# Spring datasource examples for prod profile
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/chok?serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=chok-spring
SPRING_DATASOURCE_PASSWORD=chok-spring

# Notes:
# - This file contains development placeholders only.
# - Do not put real secrets in this file.
# - Copy values into your local environment or a private .env file if needed.
