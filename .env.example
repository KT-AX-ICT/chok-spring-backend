# Spring profile
# local  → H2 파일모드 (./data/chok) — 로컬 개발 기본값
# dev    → H2 in-memory
# prod   → MySQL (SPRING_DATASOURCE_* 별도 설정 필요)
SPRING_PROFILES_ACTIVE=local

# FastAPI base URL
PYTHON_BASE_URL=http://localhost:8000

# MySQL credentials (prod profile only)
MYSQL_DATABASE=chok
MYSQL_USER=chok-spring
MYSQL_PASSWORD=chok-spring
MYSQL_ROOT_PASSWORD=root

# Notes:
# - This file contains development placeholders only.
# - Do not put real secrets in this file.
# - Copy values into your local environment or a private .env file if needed.
# - SPRING_DATASOURCE_URL/USERNAME/PASSWORD 환경변수는 local/dev 프로파일 설정을 덮어쓰므로
#   prod 배포 환경에서만 설정할 것.

# --- 분석 잡 (Scheduler/Startup) — Spring 프로퍼티 analysis.* / 트리거 기본 off ---
# 실제 적용은 보통 --args 또는 application.yaml/프로파일로. (.env는 Spring이 자동 로드하지 않음)
# 5분 주기 스케줄러 활성화 (analysis.scheduler.enabled)
ANALYSIS_SCHEDULER_ENABLED=false
# 스케줄러 주기 ms (analysis.scheduler.fixed-rate-ms)
ANALYSIS_SCHEDULER_FIXED_RATE_MS=300000
# 시작 시 1회 자동 분석 (analysis.run-on-startup) — local/prod 프로파일에서만
ANALYSIS_RUN_ON_STARTUP=false
# FastAPI batch 묶음 크기 (analysis.chunk-size)
ANALYSIS_CHUNK_SIZE=20
# 스케줄러 1주기 처리 상한 (analysis.default-limit)
ANALYSIS_DEFAULT_LIMIT=200
# 시작 1회 처리 상한 (analysis.startup-limit)
ANALYSIS_STARTUP_LIMIT=500
